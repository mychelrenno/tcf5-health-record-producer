    {
      "name": "Exemplo 2 - http://127.0.0.1:8083/mapping-rules",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Try to extract clientId from Location header first, then from body",
              "var location = pm.response.headers.get('Location') || pm.response.headers.get('location');",
              "if (location) {",
              "  var parts = location.split('/');",
              "  var clientId = parts[parts.length-1];",
              "  pm.environment.set('clientId', clientId);",
              "  console.log('Saved clientId from Location header:', clientId);",
              "} else {",
              "  try {",
              "    var body = pm.response.json();",
              "    if (body && body.clientId) {",
              "      pm.environment.set('clientId', body.clientId);",
              "      console.log('Saved clientId from response body:', body.clientId);",
              "    } else if (typeof body === 'string' && body.length > 0) {",
              "      // may be the API returns the id as plain text",
              "      pm.environment.set('clientId', body);",
              "      console.log('Saved clientId from response text:', body);",
              "    }",
              "  } catch (err) {",
              "    console.log('Could not parse response to extract clientId:', err);",
              "  }",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
